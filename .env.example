# Copy to .env and fill in your values
AWS_PROFILE=your-aws-profile
AWS_REGION=us-east-1

# Optional — defaults are created by CloudFormation on first run
# BUCKET_NAME=novvys-site-123456789012
# STACK_NAME=novvys-website

# Optional — after you attach a custom domain, set your canonical URL
# SITE_URL=https://novvys.com
# BASE_PATH=/
