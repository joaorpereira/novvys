# Copy to .env and fill in your values
AWS_PROFILE=your-aws-profile
AWS_REGION=us-east-1

# Optional — defaults are created by CloudFormation on first run
# BUCKET_NAME=novvys-site-123456789012
# STACK_NAME=novvys-website

# Optional — after you attach a custom domain, set your canonical URL
# SITE_URL=https://www.novvys.com
# BASE_PATH=/
# ACM_CERTIFICATE_ARN=arn:aws:acm:us-east-1:123456789012:certificate/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# APEX_DOMAIN=novvys.com
# WWW_DOMAIN=www.novvys.com
