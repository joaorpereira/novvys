---
import type { Locale } from "../i18n/config";
import { getLocalePath, localeHtmlLang, localeHrefLang, locales, defaultLocale } from "../i18n/config";
import { useTranslations } from "../i18n";
import { SITE, localeOgLocale } from "../config/site";
import { META_CONTENT_SECURITY_POLICY } from "../config/security-headers";
import { absoluteUrl, withBase } from "../utils/urls";
import { getAlternateUrls } from "../utils/seo";
import "../styles/global.css";

interface BlogPostSeo {
  type: "article";
  title: string;
  description: string;
  canonicalPath: string;
  publishedTime: string;
  author: string;
  category: string;
  breadcrumbs: { name: string; path: string }[];
}

interface BlogListSeo {
  type: "blog";
  title: string;
  description: string;
  canonicalPath: string;
  posts: { slug: string; title: string; path: string }[];
}

interface Props {
  locale: Locale;
  pageSeo?: BlogPostSeo | BlogListSeo;
}

const { locale, pageSeo } = Astro.props;
const t = useTranslations(locale);
const lang = localeHtmlLang[locale];
const siteUrl = absoluteUrl("/");
const ogLocale = localeOgLocale[locale];
const ogImage = absoluteUrl("images/hero-tech-visual.avif");
const faviconUrl = withBase("favicon.svg");

const pageTitle = pageSeo?.title ?? t.meta.title;
const pageDescription = pageSeo?.description ?? t.meta.description;
const canonicalUrl = pageSeo?.canonicalPath
  ? absoluteUrl(pageSeo.canonicalPath)
  : absoluteUrl(getLocalePath(locale));
const alternateUrls = getAlternateUrls(pageSeo?.canonicalPath ?? getLocalePath(locale));
const ogType = pageSeo?.type === "article" ? "article" : "website";

const baseGraph = [
  {
    "@type": ["Organization", "ProfessionalService"],
    "@id": `${siteUrl}#organization`,
    name: SITE.name,
    legalName: SITE.legalName,
    slogan: SITE.tagline,
    description: t.meta.description,
    url: siteUrl,
    logo: absoluteUrl("favicon.svg"),
    email: SITE.email,
    telephone: SITE.phone,
    address: {
      "@type": "PostalAddress",
      addressLocality: SITE.location.city,
      addressRegion: SITE.location.region,
      addressCountry: SITE.location.country,
    },
    areaServed: {
      "@type": "Country",
      name: "Brazil",
    },
    knowsAbout: [
      "Software Development",
      "Cloud Infrastructure",
      "Data Engineering",
      "Mobile Applications",
      "DevOps",
    ],
    contactPoint: {
      "@type": "ContactPoint",
      contactType: "customer service",
      email: SITE.email,
      telephone: SITE.phone,
      availableLanguage: ["Portuguese", "English", "Spanish"],
    },
  },
  {
    "@type": "WebSite",
    "@id": `${siteUrl}#website`,
    name: SITE.name,
    url: siteUrl,
    inLanguage: lang,
    publisher: { "@id": `${siteUrl}#organization` },
  },
];

function buildStructuredData() {
  if (pageSeo?.type === "article") {
    const articleUrl = absoluteUrl(pageSeo.canonicalPath);
    return {
      "@context": "https://schema.org",
      "@graph": [
        ...baseGraph,
        {
          "@type": "BlogPosting",
          "@id": `${articleUrl}#article`,
          headline: pageSeo.title,
          description: pageSeo.description,
          datePublished: pageSeo.publishedTime,
          dateModified: pageSeo.publishedTime,
          image: ogImage,
          author: {
            "@type": "Organization",
            name: pageSeo.author,
            "@id": `${siteUrl}#organization`,
          },
          publisher: { "@id": `${siteUrl}#organization` },
          articleSection: pageSeo.category,
          inLanguage: lang,
          url: articleUrl,
          isPartOf: { "@id": `${siteUrl}#website` },
        },
        {
          "@type": "BreadcrumbList",
          itemListElement: pageSeo.breadcrumbs.map((crumb, i) => ({
            "@type": "ListItem",
            position: i + 1,
            name: crumb.name,
            item: absoluteUrl(crumb.path),
          })),
        },
      ],
    };
  }

  if (pageSeo?.type === "blog") {
    const blogUrl = absoluteUrl(pageSeo.canonicalPath);
    return {
      "@context": "https://schema.org",
      "@graph": [
        ...baseGraph,
        {
          "@type": "Blog",
          "@id": `${blogUrl}#blog`,
          name: `Blog ${SITE.name}`,
          description: pageSeo.description,
          url: blogUrl,
          inLanguage: lang,
          publisher: { "@id": `${siteUrl}#organization` },
        },
        {
          "@type": "ItemList",
          "@id": `${blogUrl}#posts`,
          itemListElement: pageSeo.posts.map((post, i) => ({
            "@type": "ListItem",
            position: i + 1,
            url: absoluteUrl(post.path),
            name: post.title,
          })),
        },
        {
          "@type": "BreadcrumbList",
          itemListElement: [
            { "@type": "ListItem", position: 1, name: SITE.name, item: siteUrl },
            { "@type": "ListItem", position: 2, name: "Blog", item: blogUrl },
          ],
        },
      ],
    };
  }

  return {
    "@context": "https://schema.org",
    "@graph": [
      ...baseGraph,
      {
        "@type": "WebPage",
        "@id": `${canonicalUrl}#webpage`,
        url: canonicalUrl,
        name: pageTitle,
        description: pageDescription,
        isPartOf: { "@id": `${siteUrl}#website` },
        inLanguage: lang,
      },
    ],
  };
}

const structuredData = buildStructuredData();
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content={SITE.name} />
    <meta name="theme-color" content="#07111f" />
    <meta name="google-site-verification" content="tDk6H7rypO672-ufZvouZR5Nhf-EOIcmxj69D9hSKvY" />
    <meta http-equiv="Content-Security-Policy" content={META_CONTENT_SECURITY_POLICY} />
    <link rel="icon" type="image/svg+xml" href={faviconUrl} />
    <link rel="canonical" href={canonicalUrl} />

    {
      locales.map((loc) => (
        <link
          rel="alternate"
          hreflang={localeHrefLang[loc]}
          href={absoluteUrl(alternateUrls[loc])}
        />
      ))
    }
    <link rel="alternate" hreflang="x-default" href={absoluteUrl(alternateUrls[defaultLocale])} />

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={t.a11y.heroImageAlt} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    {pageSeo?.type === "article" && (
      <>
        <meta property="article:published_time" content={pageSeo.publishedTime} />
        <meta property="article:modified_time" content={pageSeo.publishedTime} />
        <meta property="article:author" content={pageSeo.author} />
        <meta property="article:section" content={pageSeo.category} />
      </>
    )}
    {
      locales
        .filter((loc) => loc !== locale)
        .map((loc) => (
          <meta property="og:locale:alternate" content={localeOgLocale[loc]} />
        ))
    }

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={SITE.twitterHandle} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={t.a11y.heroImageAlt} />

    <title>{pageTitle}</title>

    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <a href="#main-content" class="skip-link">{t.a11y.skipToContent}</a>
    <slot />
    <script>
      import "../scripts/init.ts";
    </script>
  </body>
</html>
