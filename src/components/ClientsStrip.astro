---
const clients = [
  "Fintech Corp",
  "LogiTech",
  "HealthPlus",
  "DataFlow",
  "CloudScale",
  "RetailPro",
];
---

<div class="clients-strip">
  <div class="container clients-inner">
    <p class="clients-label">Empresas que confiam em nós</p>
    <div class="clients-track" aria-hidden="true">
      <div class="clients-logos">
        {
          [...clients, ...clients].map((client) => (
            <span class="client-logo">{client}</span>
          ))
        }
      </div>
    </div>
  </div>
</div>

<style>
  .clients-strip {
    position: relative;
    z-index: 2;
    padding: 2rem 0 3rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    background: linear-gradient(180deg, rgba(5, 10, 21, 0.4) 0%, transparent 100%);
  }

  .clients-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .clients-label {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.35);
  }

  .clients-track {
    width: 100%;
    overflow: hidden;
    mask-image: linear-gradient(90deg, transparent, black 15%, black 85%, transparent);
    -webkit-mask-image: linear-gradient(90deg, transparent, black 15%, black 85%, transparent);
  }

  .clients-logos {
    display: flex;
    gap: 3rem;
    width: max-content;
    animation: marquee 30s linear infinite;
  }

  .client-logo {
    flex-shrink: 0;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: rgba(255, 255, 255, 0.25);
    white-space: nowrap;
    transition: color 0.3s;
  }

  .client-logo:hover {
    color: rgba(255, 255, 255, 0.5);
  }

  @keyframes marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .clients-logos {
      animation: none;
      flex-wrap: wrap;
      justify-content: center;
      width: 100%;
      gap: 1.5rem 2.5rem;
    }

    .clients-track {
      mask-image: none;
      -webkit-mask-image: none;
    }
  }
</style>
