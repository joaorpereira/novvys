---
import type { Locale } from "../i18n/config";
import { useTranslations } from "../i18n";
import { withBase } from "../utils/urls";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const badgeIcons = ["star", "check", "team"] as const;
const heroImageSrc = withBase("images/hero-tech-visual.png");
---

<div class="hero-visual-wrap hero-enter">
  <div class="hero-visual-glow" aria-hidden="true"></div>

  <figure class="hero-visual-frame">
    <img
      src={heroImageSrc}
      alt={t.a11y.heroImageAlt}
      width="1536"
      height="1024"
      loading="eager"
      decoding="async"
      fetchpriority="high"
      class="hero-visual-image"
    />

    <div class="hero-trust-badges" role="list" aria-label={t.hero.trustLabel}>
      {
        t.hero.trustBadges.map((badge, index) => (
          <div
            class="hero-trust-badge"
            role="listitem"
            style={`--badge-delay: ${index * 120}ms`}
          >
            <span class="hero-trust-badge-icon" aria-hidden="true">
              {badgeIcons[index] === "star" && (
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <path
                    d="M8 1.5L9.8 5.8L14.5 6.3L11 9.2L12 14L8 11.6L4 14L5 9.2L1.5 6.3L6.2 5.8L8 1.5Z"
                    stroke="currentColor"
                    stroke-width="1.25"
                    stroke-linejoin="round"
                  />
                </svg>
              )}
              {badgeIcons[index] === "check" && (
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <path
                    d="M4 8.5L6.5 11L12 5.5"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                  <circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.25" />
                </svg>
              )}
              {badgeIcons[index] === "team" && (
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <circle cx="6" cy="5.5" r="2" stroke="currentColor" stroke-width="1.25" />
                  <circle cx="11" cy="6.5" r="1.75" stroke="currentColor" stroke-width="1.25" />
                  <path
                    d="M2.5 13.5C2.5 11.5 4 10 6 10C7.2 10 8.2 10.5 9 11.3"
                    stroke="currentColor"
                    stroke-width="1.25"
                    stroke-linecap="round"
                  />
                  <path
                    d="M11 10C12.4 10 13.5 11.1 13.5 12.5V13.5"
                    stroke="currentColor"
                    stroke-width="1.25"
                    stroke-linecap="round"
                  />
                </svg>
              )}
            </span>
            <div class="hero-trust-badge-text">
              <strong>{badge.title}</strong>
              <span>{badge.subtitle}</span>
            </div>
          </div>
        ))
      }
    </div>
  </figure>
</div>

<style>
  .hero-visual-wrap {
    position: relative;
    width: 100%;
    height: auto;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem;
    overflow: visible;
  }

  .hero-visual-glow {
    position: absolute;
    width: 70%;
    height: 60%;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(37, 99, 235, 0.22) 0%,
      rgba(37, 99, 235, 0.05) 50%,
      transparent 72%
    );
    pointer-events: none;
    z-index: 0;
    transform: translate(8%, 4%);
    animation: hero-glow-pulse 6s ease-in-out infinite;
  }

  @keyframes hero-glow-pulse {
    0%,
    100% {
      opacity: 0.75;
      transform: translate(8%, 4%) scale(1);
    }
    50% {
      opacity: 1;
      transform: translate(8%, 4%) scale(1.05);
    }
  }

  .hero-visual-frame {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 580px;
    margin: 0;
    overflow: visible;
  }

  .hero-visual-image {
    width: 100%;
    height: auto;
    max-width: 100%;
    display: block;
    object-fit: contain;
    object-position: center;
    filter: drop-shadow(0 20px 48px rgba(0, 0, 0, 0.45));
  }

  .hero-trust-badges {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero-trust-badge {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.625rem 0.875rem;
    border-radius: 0.75rem;
    background: rgba(7, 17, 31, 0.88);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border: 1px solid rgba(96, 165, 250, 0.22);
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.4),
      0 0 20px rgba(37, 99, 235, 0.12);
    animation: badge-float 5s ease-in-out infinite;
    animation-delay: var(--badge-delay, 0ms);
    max-width: 11.5rem;
  }

  /* Keep badges inside the image bounds so nothing gets clipped */
  .hero-trust-badge:nth-child(1) {
    top: 8%;
    left: 4%;
  }

  .hero-trust-badge:nth-child(2) {
    top: 40%;
    right: 4%;
  }

  .hero-trust-badge:nth-child(3) {
    bottom: 12%;
    left: 12%;
  }

  @keyframes badge-float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-6px);
    }
  }

  .hero-trust-badge-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    flex-shrink: 0;
    border-radius: 0.5rem;
    background: rgba(37, 99, 235, 0.2);
    color: #60a5fa;
  }

  .hero-trust-badge-text {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    min-width: 0;
  }

  .hero-trust-badge-text strong {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #ffffff;
    line-height: 1.2;
  }

  .hero-trust-badge-text span {
    font-size: 0.625rem;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.3;
  }

  @media (max-width: 1023px) {
    .hero-visual-frame {
      max-width: min(100%, 400px);
    }

    .hero-trust-badge:nth-child(1) {
      top: 4%;
      left: 2%;
    }

    .hero-trust-badge:nth-child(2) {
      top: auto;
      bottom: 8%;
      right: 2%;
    }

    .hero-trust-badge:nth-child(3) {
      display: none;
    }

    .hero-trust-badge {
      max-width: 10rem;
      padding: 0.5rem 0.75rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-visual-glow,
    .hero-trust-badge {
      animation: none;
    }
  }
</style>
