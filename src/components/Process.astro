---
import type { Locale } from "../i18n/config";
import { useTranslations } from "../i18n";
import { stepIcons, stepNumbers } from "../data/content";
import Icon from "./Icon.astro";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section class="process" id="processo">
  <div class="container">
    <div class="process-header reveal">
      <span class="section-label">{t.process.sectionLabel}</span>
      <h2 class="process-title">{t.process.title}</h2>
    </div>

    <div class="process-timeline">
      <div class="process-line" aria-hidden="true">
        <div class="process-line-fill reveal-line"></div>
      </div>

      <div class="process-steps">
        {
          t.process.steps.map((step, index) => (
            <div
              class="process-step reveal"
              style={`--reveal-delay: ${index * 150}ms`}
            >
              <div class="step-icon-wrap">
                <div class="step-icon">
                  <Icon name={stepIcons[index]} size={24} />
                </div>
              </div>
              <span class="step-number">{stepNumbers[index]}</span>
              <h3 class="step-title">{step.title}</h3>
              <p class="step-desc">{step.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .process {
    background: #ffffff;
    color: #07111f;
    padding: 6rem 0;
  }

  .process-header {
    margin-bottom: 4rem;
    max-width: 560px;
  }

  .process-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: #07111f;
  }

  .process-timeline {
    position: relative;
  }

  .process-line {
    display: none;
    position: absolute;
    top: 1.75rem;
    left: 10%;
    right: 10%;
    height: 2px;
    background: rgba(7, 17, 31, 0.1);
    overflow: hidden;
  }

  .process-line-fill {
    width: 100%;
    height: 100%;
    background: #2563eb;
  }

  .process-steps {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    position: relative;
  }

  .process-step {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
    position: relative;
    padding-left: 1.5rem;
    border-left: 2px dotted rgba(37, 99, 235, 0.25);
  }

  .process-step:last-child {
    border-left-color: transparent;
  }

  .step-icon-wrap {
    margin-bottom: 1rem;
  }

  .step-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 50%;
    border: 1px solid rgba(37, 99, 235, 0.2);
    background: rgba(37, 99, 235, 0.05);
    color: #2563eb;
  }

  .step-number {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: #2563eb;
    margin-bottom: 0.5rem;
  }

  .step-title {
    font-size: 1rem;
    font-weight: 700;
    color: #07111f;
    margin-bottom: 0.5rem;
  }

  .step-desc {
    font-size: 0.875rem;
    line-height: 1.6;
    color: #64748b;
  }

  @media (min-width: 768px) {
    .process-steps {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }
  }

  @media (min-width: 1024px) {
    .process-line {
      display: block;
    }

    .process-steps {
      grid-template-columns: repeat(5, 1fr);
      gap: 1.5rem;
    }

    .process-step {
      align-items: center;
      text-align: center;
      padding-left: 0;
      border-left: none;
    }
  }
</style>
