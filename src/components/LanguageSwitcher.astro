---
import type { Locale } from "../i18n/config";
import { locales, localeLabels, getLocalePath } from "../i18n/config";
import { useTranslations } from "../i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<div class="lang-switcher">
  <span class="sr-only" id="lang-switcher-label">{t.header.selectLanguage}</span>
  <button
    class="lang-toggle"
    type="button"
    aria-labelledby="lang-switcher-label lang-current"
    aria-expanded="false"
    aria-haspopup="true"
    aria-controls="lang-menu"
    id="lang-toggle"
  >
    <span id="lang-current">{localeLabels[locale]}</span>
    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
      <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
    </svg>
  </button>

  <ul class="lang-menu" id="lang-menu" role="menu" aria-label={t.header.languageMenu} hidden>
    {
      locales.map((loc) => (
        <li role="none">
          <a
            href={getLocalePath(loc)}
            class:list={["lang-option", { "lang-option--active": loc === locale }]}
            role="menuitem"
            hreflang={loc}
            lang={loc}
            aria-current={loc === locale ? "page" : undefined}
          >
            {localeLabels[loc]}
          </a>
        </li>
      ))
    }
  </ul>
</div>

<script>
  import "../scripts/trusted-types.ts";
  import { focusFirstElement, trapFocus } from "../scripts/a11y.ts";

  const toggle = document.getElementById("lang-toggle");
  const menu = document.getElementById("lang-menu");

  if (toggle && menu) {
    let releaseFocusTrap: (() => void) | null = null;

    const closeMenu = () => {
      toggle.setAttribute("aria-expanded", "false");
      menu.hidden = true;
      releaseFocusTrap?.();
      releaseFocusTrap = null;
    };

    const openMenu = () => {
      toggle.setAttribute("aria-expanded", "true");
      menu.hidden = false;
      focusFirstElement(menu);
      releaseFocusTrap = trapFocus(menu);
    };

    toggle.addEventListener("click", (event) => {
      event.stopPropagation();
      const isOpen = toggle.getAttribute("aria-expanded") === "true";
      if (isOpen) {
        closeMenu();
      } else {
        openMenu();
      }
    });

    menu.addEventListener("click", (event) => event.stopPropagation());
    document.addEventListener("click", closeMenu);

    menu.addEventListener("keydown", (event) => {
      const items = Array.from(menu.querySelectorAll<HTMLElement>('[role="menuitem"]'));
      const index = items.indexOf(document.activeElement as HTMLElement);

      if (event.key === "ArrowDown") {
        event.preventDefault();
        items[(index + 1) % items.length]?.focus();
      }

      if (event.key === "ArrowUp") {
        event.preventDefault();
        items[(index - 1 + items.length) % items.length]?.focus();
      }

      if (event.key === "Home") {
        event.preventDefault();
        items[0]?.focus();
      }

      if (event.key === "End") {
        event.preventDefault();
        items[items.length - 1]?.focus();
      }
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && toggle.getAttribute("aria-expanded") === "true") {
        closeMenu();
        toggle.focus();
      }
    });
  }
</script>

<style>
  .lang-switcher {
    position: relative;
  }

  .lang-toggle {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.5rem 0.75rem;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 0.375rem;
    background: transparent;
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.75rem;
    font-weight: 600;
    cursor: pointer;
    transition: border-color 0.2s;
  }

  .lang-toggle:hover,
  .lang-toggle[aria-expanded="true"] {
    border-color: rgba(255, 255, 255, 0.35);
  }

  .lang-toggle:focus-visible {
    outline: 2px solid #60a5fa;
    outline-offset: 3px;
  }

  .lang-menu {
    position: absolute;
    top: calc(100% + 0.5rem);
    right: 0;
    min-width: 5rem;
    list-style: none;
    padding: 0.375rem;
    margin: 0;
    border-radius: 0.5rem;
    background: rgba(7, 17, 31, 0.95);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
    z-index: 200;
  }

  .lang-option {
    display: block;
    padding: 0.5rem 0.75rem;
    border-radius: 0.375rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.7);
    transition: background 0.2s, color 0.2s;
  }

  .lang-option:hover {
    background: rgba(255, 255, 255, 0.06);
    color: #ffffff;
  }

  .lang-option:focus-visible {
    outline: 2px solid #60a5fa;
    outline-offset: -2px;
  }

  .lang-option--active,
  .lang-option[aria-current="page"] {
    color: #2563eb;
    background: rgba(37, 99, 235, 0.1);
  }
</style>
