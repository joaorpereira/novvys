---
import type { Locale } from "../i18n/config";
import { locales, localeLabels, getLocalePath } from "../i18n/config";

interface Props {
  locale: Locale;
  label: string;
}

const { locale, label } = Astro.props;
---

<div class="lang-switcher">
  <button
    class="lang-toggle"
    type="button"
    aria-label={label}
    aria-expanded="false"
    aria-haspopup="listbox"
    id="lang-toggle"
  >
    {localeLabels[locale]}
    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
      <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
    </svg>
  </button>

  <ul class="lang-menu" id="lang-menu" role="listbox" hidden>
    {
      locales.map((loc) => (
        <li role="option" aria-selected={loc === locale}>
          <a
            href={getLocalePath(loc)}
            class:list={["lang-option", { "lang-option--active": loc === locale }]}
            hreflang={loc}
          >
            {localeLabels[loc]}
          </a>
        </li>
      ))
    }
  </ul>
</div>

<script>
  const toggle = document.getElementById("lang-toggle");
  const menu = document.getElementById("lang-menu");

  if (toggle && menu) {
    const closeMenu = () => {
      toggle.setAttribute("aria-expanded", "false");
      menu.hidden = true;
    };

    toggle.addEventListener("click", (e) => {
      e.stopPropagation();
      const isOpen = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", String(!isOpen));
      menu.hidden = isOpen;
    });

    document.addEventListener("click", closeMenu);
    menu.addEventListener("click", (e) => e.stopPropagation());
  }
</script>

<style>
  .lang-switcher {
    position: relative;
  }

  .lang-toggle {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.5rem 0.75rem;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 0.375rem;
    background: transparent;
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.75rem;
    font-weight: 600;
    cursor: pointer;
    transition: border-color 0.2s;
  }

  .lang-toggle:hover,
  .lang-toggle[aria-expanded="true"] {
    border-color: rgba(255, 255, 255, 0.35);
  }

  .lang-menu {
    position: absolute;
    top: calc(100% + 0.5rem);
    right: 0;
    min-width: 5rem;
    list-style: none;
    padding: 0.375rem;
    border-radius: 0.5rem;
    background: rgba(7, 17, 31, 0.95);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
    z-index: 200;
  }

  .lang-option {
    display: block;
    padding: 0.5rem 0.75rem;
    border-radius: 0.375rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.7);
    transition: background 0.2s, color 0.2s;
  }

  .lang-option:hover {
    background: rgba(255, 255, 255, 0.06);
    color: #ffffff;
  }

  .lang-option--active {
    color: #2563eb;
    background: rgba(37, 99, 235, 0.1);
  }
</style>
