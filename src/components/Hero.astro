---
import type { Locale } from "../i18n/config";
import { useTranslations } from "../i18n";
import Backdrop from "./Backdrop.astro";
import ClientsStrip from "./ClientsStrip.astro";
import GlobeCanvas from "./islands/GlobeCanvas";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section class="hero" id="hero">
  <Backdrop variant="hero" />
  <div class="hero-accent hero-accent--tl" aria-hidden="true"></div>
  <div class="hero-accent hero-accent--br" aria-hidden="true"></div>

  <div class="container hero-grid">
    <div class="hero-content">
      <div class="hero-badge hero-enter">
        <span class="hero-badge-dot" aria-hidden="true"></span>
        {t.hero.badge}
      </div>

      <h1 class="hero-title hero-enter">
        {t.hero.title} <span class="hero-highlight">{t.hero.titleHighlight}</span>
      </h1>

      <p class="hero-subtitle hero-enter">
        {t.hero.subtitle}
      </p>

      <div class="hero-buttons hero-enter">
        <a href="#servicos" class="btn-primary hero-btn-primary">
          {t.hero.ctaPrimary}
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
        <a href="#cases" class="btn-outline">
          {t.hero.ctaSecondary}
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.5" />
            <path d="M6.5 8L8 9.5L10.5 6.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>

      <div class="hero-highlights hero-enter">
        {
          t.hero.highlights.map((item) => (
            <div class="hero-highlight-item">
              <span class="hero-highlight-value">{item.value}</span>
              <span class="hero-highlight-label">{item.label}</span>
            </div>
          ))
        }
      </div>
    </div>

    <div class="hero-visual">
      <div class="globe-frame" aria-hidden="true">
        <span class="globe-ring globe-ring--outer"></span>
        <span class="globe-ring globe-ring--inner"></span>
        <span class="globe-dot globe-dot--1"></span>
        <span class="globe-dot globe-dot--2"></span>
        <span class="globe-dot globe-dot--3"></span>
      </div>
      <GlobeCanvas client:visible />
    </div>
  </div>

  <ClientsStrip locale={locale} />

  <a href="#stats" class="scroll-cue" aria-label={t.hero.scrollAria}>
    <span class="scroll-cue-text">{t.hero.scrollLabel}</span>
    <span class="scroll-cue-line"></span>
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 7rem 0 0;
    overflow: hidden;
    background: var(--bg-primary);
  }

  .hero-accent {
    position: absolute;
    width: 1px;
    background: linear-gradient(180deg, transparent, rgba(37, 99, 235, 0.4), transparent);
    z-index: 1;
    pointer-events: none;
  }

  .hero-accent--tl {
    top: 12%;
    left: 8%;
    height: 120px;
    transform: rotate(-15deg);
  }

  .hero-accent--br {
    bottom: 25%;
    right: 12%;
    height: 80px;
    transform: rotate(20deg);
    opacity: 0.5;
  }

  .hero-grid {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
    flex: 1;
    padding-bottom: 2rem;
  }

  .hero-content {
    max-width: 580px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    margin-bottom: 1.75rem;
    border-radius: 999px;
    border: 1px solid rgba(37, 99, 235, 0.35);
    background: rgba(37, 99, 235, 0.08);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #60a5fa;
    box-shadow: 0 0 24px rgba(37, 99, 235, 0.12);
  }

  .hero-badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #2563eb;
    box-shadow: 0 0 8px #2563eb;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.6;
      transform: scale(0.85);
    }
  }

  .hero-title {
    font-size: clamp(2.5rem, 5.5vw, 4rem);
    font-weight: 800;
    line-height: 1.02;
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
  }

  .hero-highlight {
    background: linear-gradient(135deg, #60a5fa 0%, #2563eb 50%, #1d4ed8 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.125rem);
    line-height: 1.75;
    color: #94a3b8;
    margin-bottom: 2rem;
    max-width: 520px;
  }

  .hero-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }

  .hero-btn-primary {
    box-shadow: 0 4px 24px rgba(37, 99, 235, 0.4);
  }

  .hero-highlights {
    display: flex;
    gap: 2rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .hero-highlight-item {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .hero-highlight-value {
    font-size: 1.25rem;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .hero-highlight-label {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.4);
  }

  .hero-visual {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .globe-frame {
    position: absolute;
    inset: -10%;
    pointer-events: none;
  }

  .globe-ring {
    position: absolute;
    border-radius: 50%;
    border: 1px solid rgba(37, 99, 235, 0.15);
  }

  .globe-ring--outer {
    inset: 0;
    animation: ring-pulse 4s ease-in-out infinite;
  }

  .globe-ring--inner {
    inset: 15%;
    border-color: rgba(37, 99, 235, 0.08);
    animation: ring-pulse 4s ease-in-out infinite reverse;
  }

  .globe-dot {
    position: absolute;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #2563eb;
    box-shadow: 0 0 12px rgba(37, 99, 235, 0.8);
  }

  .globe-dot--1 {
    top: 5%;
    right: 20%;
    animation: dot-float 6s ease-in-out infinite;
  }

  .globe-dot--2 {
    bottom: 15%;
    left: 10%;
    animation: dot-float 8s ease-in-out infinite -2s;
  }

  .globe-dot--3 {
    top: 40%;
    right: 5%;
    width: 4px;
    height: 4px;
    animation: dot-float 7s ease-in-out infinite -4s;
  }

  .scroll-cue {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: rgba(255, 255, 255, 0.3);
    transition: color 0.2s;
  }

  .scroll-cue:hover {
    color: rgba(255, 255, 255, 0.6);
  }

  .scroll-cue-text {
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .scroll-cue-line {
    display: block;
    width: 1px;
    height: 40px;
    background: linear-gradient(180deg, rgba(37, 99, 235, 0.6), transparent);
    animation: scroll-line 2s ease-in-out infinite;
  }

  @keyframes ring-pulse {
    0%,
    100% {
      transform: scale(1);
      opacity: 1;
    }
    50% {
      transform: scale(1.02);
      opacity: 0.7;
    }
  }

  @keyframes dot-float {
    0%,
    100% {
      transform: translate(0, 0);
    }
    50% {
      transform: translate(8px, -8px);
    }
  }

  @keyframes scroll-line {
    0% {
      transform: scaleY(0);
      transform-origin: top;
    }
    50% {
      transform: scaleY(1);
      transform-origin: top;
    }
    51% {
      transform: scaleY(1);
      transform-origin: bottom;
    }
    100% {
      transform: scaleY(0);
      transform-origin: bottom;
    }
  }

  @media (min-width: 768px) {
    .hero {
      padding-top: 8rem;
    }
  }

  @media (min-width: 1024px) {
    .hero-grid {
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
    }

    .hero-visual {
      justify-content: flex-end;
    }

    .scroll-cue {
      bottom: 2rem;
    }
  }

  @media (max-width: 767px) {
    .scroll-cue {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .hero-highlights {
      gap: 1.25rem;
    }

    .hero-highlight-value {
      font-size: 1.125rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .globe-ring--outer,
    .globe-ring--inner,
    .globe-dot,
    .scroll-cue-line,
    .hero-badge-dot {
      animation: none;
    }

    .hero-enter {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }
</style>
