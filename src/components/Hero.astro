---
import type { Locale } from "../i18n/config";
import { useTranslations } from "../i18n";
import Backdrop from "./Backdrop.astro";
import HeroVisual from "./HeroVisual.astro";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section class="hero" id="hero" aria-label="Hero">
  <Backdrop variant="hero" />

  <div class="container hero-container">
    <div class="hero-grid">
      <div class="hero-content">
        <p class="hero-badge hero-enter">
          <span class="hero-badge-dot" aria-hidden="true"></span>
          {t.hero.badge}
        </p>

        <h1 class="hero-title hero-enter">
          {t.hero.title}
          <span class="hero-highlight">{t.hero.titleHighlight}</span>
        </h1>

        <p class="hero-subtitle hero-enter">{t.hero.subtitle}</p>

        <div class="hero-buttons hero-enter">
          <a href="#servicos" class="btn-primary hero-btn-primary">
            {t.hero.ctaPrimary}
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
          <a href="#cases" class="btn-outline">
            {t.hero.ctaSecondary}
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.5" />
              <path d="M6.5 8L8 9.5L10.5 6.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
        </div>

        <dl class="hero-highlights hero-enter">
          {
            t.hero.highlights.map((item) => (
              <div class="hero-highlight-item">
                <dt class="hero-highlight-value">{item.value}</dt>
                <dd class="hero-highlight-label">{item.label}</dd>
              </div>
            ))
          }
        </dl>
      </div>

      <div class="hero-visual">
        <HeroVisual locale={locale} />
      </div>
    </div>
  </div>

  <a href="#stats" class="scroll-cue" aria-label={t.hero.scrollAria}>
    <span class="scroll-cue-text">{t.hero.scrollLabel}</span>
    <span class="scroll-cue-line"></span>
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 6.5rem 0 4rem;
    overflow-x: clip;
    overflow-y: visible;
    background: var(--bg-primary);
  }

  .hero-container {
    position: relative;
    z-index: 2;
    width: min(1280px, 92%);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }

  .hero-content {
    max-width: 600px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    margin-bottom: 1.75rem;
    border-radius: 999px;
    border: 1px solid rgba(37, 99, 235, 0.35);
    background: rgba(37, 99, 235, 0.08);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #60a5fa;
    box-shadow: 0 0 24px rgba(37, 99, 235, 0.12);
  }

  .hero-badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #2563eb;
    box-shadow: 0 0 8px #2563eb;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.6;
      transform: scale(0.85);
    }
  }

  .hero-title {
    font-size: clamp(2.5rem, 5vw, 3.75rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
  }

  .hero-highlight {
    display: block;
    background: linear-gradient(135deg, #60a5fa 0%, #2563eb 50%, #1d4ed8 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: clamp(1rem, 1.8vw, 1.125rem);
    line-height: 1.75;
    color: #94a3b8;
    margin-bottom: 2rem;
    max-width: 520px;
  }

  .hero-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }

  .hero-btn-primary {
    box-shadow: 0 4px 24px rgba(37, 99, 235, 0.4);
  }

  .hero-highlights {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    margin: 0;
  }

  .hero-highlight-item {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    margin: 0;
  }

  .hero-highlight-value {
    font-size: 1.375rem;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .hero-highlight-label {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
    margin: 0;
  }

  /* Visual column */
  .hero-visual {
    position: relative;
    width: 100%;
    min-height: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: visible;
  }

  .scroll-cue {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: rgba(255, 255, 255, 0.35);
    transition: color 0.2s;
  }

  .scroll-cue:hover {
    color: rgba(255, 255, 255, 0.65);
  }

  .scroll-cue-text {
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .scroll-cue-line {
    display: block;
    width: 1px;
    height: 40px;
    background: linear-gradient(180deg, rgba(37, 99, 235, 0.6), transparent);
    animation: scroll-line 2s ease-in-out infinite;
  }

  @keyframes scroll-line {
    0% {
      transform: scaleY(0);
      transform-origin: top;
    }
    50% {
      transform: scaleY(1);
      transform-origin: top;
    }
    51% {
      transform: scaleY(1);
      transform-origin: bottom;
    }
    100% {
      transform: scaleY(0);
      transform-origin: bottom;
    }
  }

  @media (min-width: 1024px) {
    .hero {
      padding: 7rem 0 5rem;
    }

    .hero-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem 4rem;
    }

    .hero-highlight {
      display: inline;
    }
  }

  @media (max-width: 1023px) {
    .hero-visual {
      order: -1;
    }

    .scroll-cue {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-cue-line,
    .hero-badge-dot {
      animation: none;
    }

    .hero-enter {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }
</style>
