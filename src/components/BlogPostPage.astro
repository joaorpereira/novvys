---
import type { Locale } from "../i18n/config";
import { useTranslations, getBlogPath } from "../i18n";
import type { BlogPost } from "../lib/blogPostContent";
import { formatPostDate } from "../lib/blog";
import BlogContent from "./BlogContent.astro";

interface Props {
  post: BlogPost;
  locale: Locale;
}

const { post, locale } = Astro.props;
const t = useTranslations(locale);
const blogPath = getBlogPath(locale);
const formattedDate = formatPostDate(
  post.date,
  locale === "pt" ? "pt-BR" : locale === "es" ? "es-ES" : "en-US",
);
---

<article class="blog-post" id="main-content" aria-labelledby="post-title">
  <div class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol class="breadcrumb-list">
        <li class="breadcrumb-item">
          <a href={blogPath} class="breadcrumb-link">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M19 12H5M12 19l-7-7 7-7"/>
            </svg>
            {t.blog.backToBlog}
          </a>
        </li>
      </ol>
    </nav>

    <header class="post-header reveal">
      <div class="post-meta">
        <span class="section-label">{post.category}</span>
        <time class="post-date" datetime={post.date}>
          {t.blog.publishedOn} {formattedDate}
        </time>
        {post.author && (
          <span class="post-author">{t.blog.by} <strong>{post.author}</strong></span>
        )}
      </div>
      <h1 id="post-title" class="post-title">{post.title}</h1>
      <p class="post-description">{post.description}</p>
    </header>

    <div class="post-body reveal" style="--reveal-delay: 150ms">
      <BlogContent content={post.body} />
    </div>

    <footer class="post-footer reveal" style="--reveal-delay: 250ms">
      <a href={blogPath} class="btn-outline back-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        {t.blog.backToBlog}
      </a>
    </footer>
  </div>
</article>

<style>
  .blog-post {
    padding: 8rem 0 6rem;
  }

  .breadcrumb {
    margin-bottom: 2.5rem;
  }

  .breadcrumb-list {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .breadcrumb-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-muted);
    transition: color 0.2s;
    letter-spacing: 0.03em;
  }

  .breadcrumb-link:hover {
    color: var(--accent);
  }

  .post-header {
    max-width: 760px;
    margin-bottom: 3.5rem;
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .post-meta :global(.section-label) {
    margin-bottom: 0;
    font-size: 0.625rem;
  }

  .post-date,
  .post-author {
    font-size: 0.8125rem;
    color: var(--text-muted);
  }

  .post-author strong {
    color: rgba(255, 255, 255, 0.85);
    font-weight: 600;
  }

  .post-title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.15;
    color: #ffffff;
    margin-bottom: 1.25rem;
  }

  .post-description {
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--text-muted);
  }

  .post-body {
    max-width: 760px;
    margin-bottom: 4rem;
  }

  .post-footer {
    padding-top: 2.5rem;
    border-top: 1px solid var(--border);
  }

  .back-link {
    padding: 0.75rem 1.5rem;
    font-size: 0.8125rem;
  }
</style>
