---
import type { Locale } from "../i18n/config";
import { useTranslations, getBlogPostPath } from "../i18n";
import type { BlogPostMeta } from "../lib/blog";
import { formatPostDate } from "../lib/blog";

interface Props {
  post: BlogPostMeta;
  locale: Locale;
  index?: number;
}

const { post, locale, index = 0 } = Astro.props;
const t = useTranslations(locale);
const postPath = getBlogPostPath(locale, post.slug);
const formattedDate = formatPostDate(post.date, locale === "pt" ? "pt-BR" : locale === "es" ? "es-ES" : "en-US");
const delay = index * 100;
---

<article
  class="blog-card reveal"
  style={`--reveal-delay: ${delay}ms`}
>
  <a href={postPath} class="blog-card-link" aria-label={`${t.blog.readMore}: ${post.title}`}>
    <div class="blog-card-category">
      <span class="section-label">{post.category}</span>
    </div>
    <h2 class="blog-card-title">{post.title}</h2>
    <p class="blog-card-description">{post.description}</p>
    <footer class="blog-card-footer">
      <time class="blog-card-date" datetime={post.date}>{formattedDate}</time>
      <span class="blog-card-read-more" aria-hidden="true">
        {t.blog.readMore}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </span>
    </footer>
  </a>
</article>

<style>
  .blog-card {
    position: relative;
    border-radius: 0.75rem;
    border: 1px solid var(--border);
    background: rgba(13, 27, 45, 0.5);
    transition: border-color 0.25s, transform 0.25s, box-shadow 0.25s;
    overflow: hidden;
  }

  .blog-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(37, 99, 235, 0.04) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.3s;
    pointer-events: none;
  }

  .blog-card:hover {
    border-color: rgba(37, 99, 235, 0.35);
    transform: translateY(-3px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3);
  }

  .blog-card:hover::before {
    opacity: 1;
  }

  .blog-card-link {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    padding: 1.75rem;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .blog-card-link:focus-visible {
    outline: 2px solid #60a5fa;
    outline-offset: -2px;
    border-radius: 0.625rem;
  }

  .blog-card-category {
    display: flex;
  }

  .blog-card-category :global(.section-label) {
    margin-bottom: 0;
    font-size: 0.625rem;
  }

  .blog-card-title {
    font-size: 1.0625rem;
    font-weight: 700;
    line-height: 1.4;
    color: #ffffff;
    letter-spacing: -0.01em;
  }

  .blog-card-description {
    font-size: 0.875rem;
    line-height: 1.65;
    color: var(--text-muted);
    flex-grow: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .blog-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .blog-card-date {
    font-size: 0.75rem;
    color: var(--text-muted);
    opacity: 0.7;
  }

  .blog-card-read-more {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
    transition: gap 0.2s;
  }

  .blog-card:hover .blog-card-read-more {
    gap: 0.625rem;
  }
</style>
